# Copy to .env.vercel-dev.local for local serverless testing.
# Do not commit .env.vercel-dev.local.

# Vercel dev serves locally, but production build metadata still needs a real
# HTTPS Mini App origin. Keep this pointed at the existing app unless testing a
# real HTTPS tunnel with a matching Farcaster domain.
MINIAPP_ORIGIN=https://chain-poem-weaver.vercel.app
CHAIN_POEM_AUTH_DOMAIN=chain-poem-weaver.vercel.app

# Default local mode: JSON file store under data/random-weave-store.vercel-dev.json.
CHAIN_POEM_STORE_DRIVER=file
CHAIN_POEM_QUEUE_STORE_PATH=data/random-weave-store.vercel-dev.json

# Optional Neon/Postgres local test. Uncomment both lines after provisioning.
# CHAIN_POEM_STORE_DRIVER=postgres
# DATABASE_URL=postgres://user:password@host.neon.tech/neondb?sslmode=require

# Local-only signing secret for provenance test records. Replace locally if desired.
CHAIN_POEM_PROVENANCE_SECRET=local-vercel-dev-not-production

# Optional host/port for npm run dev:vercel.
VERCEL_DEV_HOST=127.0.0.1
VERCEL_DEV_PORT=3000
