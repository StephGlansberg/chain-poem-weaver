# Copy to .env.deploy.local and fill locally. Never commit the real file.

MINIAPP_ORIGIN=https://chain-poem-weaver.vercel.app

# Required for automated production deploys.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Usually loaded from data/farcaster-account-association.json by OP's wrapper.
FARCASTER_ACCOUNT_ASSOCIATION_HEADER=
FARCASTER_ACCOUNT_ASSOCIATION_PAYLOAD=
FARCASTER_ACCOUNT_ASSOCIATION_SIGNATURE=

# Required for live queue storage.
DATABASE_URL=

# Optional hardening.
CHAIN_POEM_PROVENANCE_SECRET=
CHAIN_POEM_ADMIN_TOKEN=
