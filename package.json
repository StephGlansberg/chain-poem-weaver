{
  "name": "chain-poem-weaver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.10.1",
  "scripts": {
    "build": "node scripts/build-static.mjs",
    "build:production": "node scripts/build-static.mjs --production",
    "dev": "node scripts/dev-server.mjs",
    "dev:vercel": "node scripts/vercel-dev.mjs",
    "dev:vercel:linked": "node scripts/vercel-dev.mjs --linked",
    "generate:assets": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/generate-assets.ps1",
    "signing:packet": "node scripts/account-association-packet.mjs",
    "deploy:target-check": "node scripts/deploy-target-check.mjs",
    "deploy:target-check:strict": "node scripts/deploy-target-check.mjs --strict",
    "deploy:production:dry-run": "node scripts/deploy-production.mjs",
    "deploy:production:live": "node scripts/deploy-production.mjs --live",
    "verify:deployment": "node scripts/verify-deployment.mjs",
    "operator:release-brief": "node scripts/operator-release-brief.mjs",
    "client:template": "node scripts/client-verification-check.mjs --template",
    "preflight:deploy": "node scripts/deploy-preflight.mjs",
    "release:packet": "node scripts/release-packet.mjs",
    "release:packet:strict": "node scripts/release-packet.mjs --strict",
    "prepare:production": "node scripts/prepare-production.mjs",
    "test:hosting": "node scripts/hosting-config-check.mjs",
    "test:vercel-dev": "node scripts/vercel-dev-check.mjs",
    "test:base": "node scripts/base-standard-web-check.mjs",
    "test:manifest": "node scripts/manifest-assert.mjs",
    "test:api": "node scripts/api-fail-closed-check.mjs",
    "test:provenance": "node scripts/provenance-canonical-check.mjs",
    "test:random-weave": "node scripts/random-weave-queue-check.mjs",
    "test:moderation": "node scripts/moderation-floor-check.mjs",
    "test:store-adapter": "node scripts/store-adapter-check.mjs",
    "test:random-weave-ui": "node scripts/random-weave-ui-contract-check.mjs",
    "test:line-receipt-contract": "node scripts/line-receipt-contract-check.mjs",
    "test:line-receipt-metadata": "node scripts/line-receipt-metadata-check.mjs",
    "test:verify-deployment": "node scripts/verify-deployment.mjs --self-test",
    "test:production-rehearsal": "node scripts/production-rehearsal-check.mjs",
    "test:client-verification": "node scripts/client-verification-check.mjs",
    "test": "node scripts/static-check.mjs && node scripts/manifest-assert.mjs && node scripts/base-standard-web-check.mjs && node scripts/hosting-config-check.mjs && node scripts/vercel-dev-check.mjs && node scripts/provenance-canonical-check.mjs && node scripts/random-weave-queue-check.mjs && node scripts/moderation-floor-check.mjs && node scripts/store-adapter-check.mjs && node scripts/random-weave-ui-contract-check.mjs && node scripts/line-receipt-contract-check.mjs && node scripts/line-receipt-metadata-check.mjs",
    "test:dist": "npm run build && node dist/scripts/static-check.mjs && node dist/scripts/manifest-assert.mjs && node dist/scripts/base-standard-web-check.mjs && node dist/scripts/hosting-config-check.mjs && node dist/scripts/vercel-dev-check.mjs && node dist/scripts/provenance-canonical-check.mjs && node dist/scripts/random-weave-queue-check.mjs && node dist/scripts/moderation-floor-check.mjs && node dist/scripts/store-adapter-check.mjs && node dist/scripts/random-weave-ui-contract-check.mjs && node dist/scripts/line-receipt-contract-check.mjs && node dist/scripts/line-receipt-metadata-check.mjs",
    "test:production": "node scripts/static-check.mjs --production && node scripts/manifest-assert.mjs --production"
  },
  "dependencies": {
    "@farcaster/quick-auth": "^0.0.8",
    "@neondatabase/serverless": "^0.10.4",
    "viem": "^2.21.54"
  }
